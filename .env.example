APP_ENV=development
APP_PORT=8080
APP_NAME=saas_gangsta

# Railway injects PORT automatically in deployment.
# Keep APP_PORT for local development only.

# Supabase PostgreSQL URL
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.fxfpcxfvrwrmmieslpxp.supabase.co:5432/postgres?sslmode=require

# Redis URL format: redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-strong-secret
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# CORS (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Railway domain (set in Railway Variables when deployed)
# Example: https://api-production-xxxx.up.railway.app
APP_DOMAIN=

# Supabase direct client (optional for future integrations)
SUPABASE_URL=https://fxfpcxfvrwrmmieslpxp.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
